generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model AdminUser {
  id           Int       @id @default(autoincrement())
  email        String    @unique
  passwordHash String    @map("password_hash")
  // admin | manager | cashier | waiter | user
  role         String    @default("user")
  name         String?
  phone        String?
  isActive     Boolean   @default(true) @map("is_active")
  resetCode    String?   @map("reset_code")
  resetCodeExp DateTime? @map("reset_code_exp")
  createdAt    DateTime  @default(now()) @map("created_at")

  ordersTaken    Order[]         @relation("OrderStaff")
  ordersServed   Order[]         @relation("OrderWaiter")
  shifts         Shift[]
  stockMovements StockMovement[]
  expenses       Expense[]

  @@map("admin_users")
}

model Category {
  id        Int        @id @default(autoincrement())
  name      String
  slug      String     @unique
  kicker    String?
  headline  String?
  sub       String?
  coverUrl  String?    @map("cover_url")
  period    String     @default("any") // any | morning | midday | evening
  sortOrder Int        @default(0) @map("sort_order")
  isActive  Boolean    @default(true) @map("is_active")
  createdAt DateTime   @default(now()) @map("created_at")
  items     MenuItem[]

  @@map("categories")
}

model MenuItem {
  id           Int           @id @default(autoincrement())
  categoryId   Int           @map("category_id")
  name         String
  description  String?
  price        Decimal       @db.Decimal(10, 2)
  imageUrl     String?       @map("image_url")
  kcal         String?
  prepTime     String?       @map("prep_time")
  pairing      String?
  sortOrder    Int           @default(0) @map("sort_order")
  isActive     Boolean       @default(true) @map("is_active")
  createdAt    DateTime      @default(now()) @map("created_at")
  category     Category      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  optionGroups OptionGroup[]
  extras       ItemExtra[]
  tags         ItemTag[]

  @@map("menu_items")
}

model OptionGroup {
  id         Int          @id @default(autoincrement())
  menuItemId Int          @map("menu_item_id")
  title      String
  sortOrder  Int          @default(0) @map("sort_order")
  createdAt  DateTime     @default(now()) @map("created_at")
  menuItem   MenuItem     @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  options    ItemOption[]

  @@map("option_groups")
}

model ItemOption {
  id            Int         @id @default(autoincrement())
  optionGroupId Int         @map("option_group_id")
  name          String
  priceAdd      Decimal     @default(0) @map("price_add") @db.Decimal(10, 2)
  sortOrder     Int         @default(0) @map("sort_order")
  createdAt     DateTime    @default(now()) @map("created_at")
  optionGroup   OptionGroup @relation(fields: [optionGroupId], references: [id], onDelete: Cascade)

  @@map("item_options")
}

model ItemExtra {
  id         Int      @id @default(autoincrement())
  menuItemId Int      @map("menu_item_id")
  name       String
  priceAdd   Decimal  @default(0) @map("price_add") @db.Decimal(10, 2)
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@map("item_extras")
}

model Tag {
  id        Int       @id @default(autoincrement())
  slug      String    @unique
  label     String
  variant   String    @default("default") // default | green | spicy
  createdAt DateTime  @default(now()) @map("created_at")
  items     ItemTag[]

  @@map("tags")
}

model ItemTag {
  menuItemId Int      @map("menu_item_id")
  tagId      Int      @map("tag_id")
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([menuItemId, tagId])
  @@map("item_tags")
}

model Banner {
  id              Int      @id @default(autoincrement())
  service         String   @unique // morning | midday | evening
  tagLabel        String   @map("tag_label")
  headline        String
  body            String
  imageUrl        String?  @map("image_url")
  ctaText         String   @map("cta_text")
  ctaCategorySlug String?  @map("cta_category_slug")
  meta1Label      String?  @map("meta1_label")
  meta1Value      String?  @map("meta1_value")
  meta2Label      String?  @map("meta2_label")
  meta2Value      String?  @map("meta2_value")
  meta3Label      String?  @map("meta3_label")
  meta3Value      String?  @map("meta3_value")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("banners")
}

model Customer {
  id        Int      @id @default(autoincrement())
  phone     String   @unique
  name      String
  address   String
  createdAt DateTime @default(now()) @map("created_at")
  orders    Order[]

  @@map("customers")
}

model PaymentSession {
  id          Int      @id @default(autoincrement())
  reference   String   @unique
  phone       String
  name        String
  address     String?
  orderType   String   @default("delivery") @map("order_type")
  tableNumber String?  @map("table_number")
  cartJson    Json     @map("cart_json")
  amount      Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("payment_sessions")
}

model Order {
  id                   Int      @id @default(autoincrement())
  customerId           Int?     @map("customer_id")
  items                Json
  total                Decimal  @db.Decimal(10, 2)
  address              String?
  orderType            String   @default("delivery") @map("order_type")
  tableNumber          String?  @map("table_number")
  // online = QR/Waafi · pos = walk-in taken by staff
  source               String   @default("online")
  staffId              Int?     @map("staff_id")
  paymentMethod        String?  @map("payment_method") // cash | card | evc | waafi
  paymentStatus        String   @default("unpaid") @map("payment_status") // unpaid | paid | refunded
  amountReceived       Decimal? @map("amount_received") @db.Decimal(10, 2)
  discount             Decimal  @default(0) @db.Decimal(10, 2)
  deliveryFee          Decimal  @default(0) @map("delivery_fee") @db.Decimal(10, 2)
  contactName          String?  @map("contact_name")
  contactPhone         String?  @map("contact_phone")
  // waiter the order is attributed to — a login AdminUser with role 'waiter'
  waiterId             Int?     @map("waiter_id")
  // pending = preauth held, awaiting admin · confirmed = admin accepted, captured · declined = admin declined, refunded
  status               String   @default("pending")
  reference            String   @unique
  paymentTransactionId String?  @map("payment_transaction_id")
  createdAt            DateTime @default(now()) @map("created_at")
  customer             Customer?  @relation(fields: [customerId], references: [id])
  staff                AdminUser? @relation("OrderStaff", fields: [staffId], references: [id])
  waiter               AdminUser? @relation("OrderWaiter", fields: [waiterId], references: [id])

  @@index([staffId])
  @@index([waiterId])
  @@map("orders")
}

model InventoryItem {
  id           Int             @id @default(autoincrement())
  name         String
  unit         String
  quantity     Decimal         @default(0) @db.Decimal(12, 3)
  reorderLevel Decimal?        @map("reorder_level") @db.Decimal(12, 3)
  costPerUnit  Decimal?        @map("cost_per_unit") @db.Decimal(10, 2)
  supplier     String?
  isActive     Boolean         @default(true) @map("is_active")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")
  movements    StockMovement[]

  @@map("inventory_items")
}

model StockMovement {
  id              Int           @id @default(autoincrement())
  inventoryItemId Int           @map("inventory_item_id")
  type            String // purchase | usage | adjustment | waste
  quantity        Decimal       @db.Decimal(12, 3) // signed delta
  unitCost        Decimal?      @map("unit_cost") @db.Decimal(10, 2)
  note            String?
  staffId         Int?          @map("staff_id")
  createdAt       DateTime      @default(now()) @map("created_at")
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  staff           AdminUser?    @relation(fields: [staffId], references: [id])

  @@index([inventoryItemId])
  @@map("stock_movements")
}

model Expense {
  id        Int        @id @default(autoincrement())
  category  String
  amount    Decimal    @db.Decimal(10, 2)
  note      String?
  staffId   Int?       @map("staff_id")
  incurredAt DateTime  @default(now()) @map("incurred_at")
  createdAt DateTime   @default(now()) @map("created_at")
  staff     AdminUser? @relation(fields: [staffId], references: [id])

  @@index([incurredAt])
  @@map("expenses")
}

model Shift {
  id           Int       @id @default(autoincrement())
  staffId      Int       @map("staff_id")
  clockIn      DateTime  @default(now()) @map("clock_in")
  clockOut     DateTime? @map("clock_out")
  openingFloat Decimal?  @map("opening_float") @db.Decimal(10, 2)
  closingCash  Decimal?  @map("closing_cash") @db.Decimal(10, 2)
  note         String?
  createdAt    DateTime  @default(now()) @map("created_at")
  staff        AdminUser @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
  @@map("shifts")
}

model SocialLink {
  id        Int      @id @default(autoincrement())
  platform  String   @unique
  value     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("social_links")
}

// Simple key/value app settings (e.g. delivery_fee). Managed on the Settings page.
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}
