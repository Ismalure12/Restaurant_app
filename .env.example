# Copy to .env and fill in real values. Do NOT commit .env.

# Neon Postgres connection string
DATABASE_URL=

# Secret used to sign JWTs (use a long random string)
JWT_SECRET=

# Vercel Blob storage token (image uploads)
BLOB_READ_WRITE_TOKEN=

# Seed admin credentials
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Outbound email (password reset / verification) — Gmail app password
EMAIL_USER=
EMAIL_APP_PASSWORD=

# Waafi / EVC payment gateway
WAAFI_MERCHANT_UID=
WAAFI_API_USER_ID=
WAAFI_API_KEY=

# POS staff logins (seed with: node scripts/seed-staff.mjs)
MANAGER_EMAIL=
MANAGER_PASSWORD=
CASHIER_EMAIL=
CASHIER_PASSWORD=

# Default delivery fee prefilled in the POS
NEXT_PUBLIC_DEFAULT_DELIVERY_FEE=2.00
